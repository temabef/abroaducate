# Example .env file for Abroaducate
# Copy this file to .env and fill in your real values

# === OpenAI (Server Only) ===
OPENAI_API_KEY=your-openai-api-key-here

# === Supabase ===
# Public (safe for client)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Private (server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Stripe ===
# Public (safe for client)
PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
# Private (server only)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# === SendGrid (Server Only) ===
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_NAME=Abroaducate
FROM_EMAIL=hello@abroaducate.com

# === Cron/Automation (Server Only) ===
CRON_SECRET=your-cron-secret

# === App URL (for emails, etc.) ===
APP_URL=https://your-app-url.com

# === External APIs (if needed) ===
COLLEGE_SCORECARD_API_KEY=your-college-scorecard-api-key