# Google Cloud Vision API Credentials
# In production (Vercel), set this as an environment variable
# Copy the contents of google-vision-credentials.json as a JSON string
GOOGLE_APPLICATION_CREDENTIALS=

# Alternative: Set individual credentials
# GOOGLE_PROJECT_ID=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_CLIENT_EMAIL=

# ---------------------------------------------------------------------------
# Email (SendGrid) – required for newsletter, contact form, digest & reminders
# See docs/EMAIL_SETUP_AND_ACTIVATION.md for full setup
# ---------------------------------------------------------------------------
# SendGrid API key (create at sendgrid.com → API Keys). Required for any sending.
SENDGRID_API_KEY=
# Sender address – must be verified in SendGrid (Single Sender or Domain Auth)
FROM_EMAIL=hello@abroaducate.com
# Optional; defaults to "Abroaducate"
FROM_NAME=Abroaducate

# Cron job secret – used to authorize POST /api/cron/send-reminders (digest, reminders)
# Use a long random string (e.g. openssl rand -hex 32)
CRON_SECRET=
