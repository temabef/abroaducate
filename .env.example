# Google Cloud Vision API Credentials
# In production (Vercel), set this as an environment variable
# Copy the contents of google-vision-credentials.json as a JSON string
GOOGLE_APPLICATION_CREDENTIALS=

# Alternative: Set individual credentials
# GOOGLE_PROJECT_ID=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_CLIENT_EMAIL=

# ---------------------------------------------------------------------------
# Customer.io - required for email automation, campaign tracking, and reminders
# ---------------------------------------------------------------------------
CUSTOMER_IO_SITE_ID=
CUSTOMER_IO_API_KEY=

# ---------------------------------------------------------------------------
# Paystack – required for African card / mobile money payments
# Get your secret key from https://dashboard.paystack.com/#/settings/developers
# Use the test key (sk_test_xxx) for development, live key (sk_live_xxx) for production
# ---------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=
