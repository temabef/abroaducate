      "permanent": true
    },
    {
      "source": "/cover-letter",
      "destination": "/cover-letters",
      "permanent": true
    },
    {
      "source": "/personal-statement",
      "destination": "/personal-statements",
      "permanent": true
    },
    {
      "source": "/academic-cv",
      "destination": "/academic-cv",
      "permanent": true
    },
    
    // Old practice tool redirects
    {
      "source": "/ielts-practice",
      "destination": "/practice/ielts",
      "permanent": true
    },
    {
      "source": "/visa-practice",
      "destination": "/visa-interview-practice",
      "permanent": true
    },
    
    // Old university redirects
    {
      "source": "/universities/:slug",
      "destination": "/universities/:slug",
      "permanent": true
    },
    {
      "source": "/university/:slug",
      "destination": "/universities/:slug",
      "permanent": true
    },
    
    // Old admin redirects
    {
      "source": "/wp-admin",
      "destination": "/admin",
      "permanent": true
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin/:path*",
      "permanent": true
    },
    
    // Old API redirects
    {
      "source": "/wp-json/:path*",
      "destination": "/api/:path*",
      "permanent": true
    },
    
    // Old feed redirects
    {
      "source": "/feed",
      "destination": "/rss.xml",
      "permanent": true
    },
    {
      "source": "/rss",
      "destination": "/rss.xml",
      "permanent": true
    },
    
    // Old sitemap redirects
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml",
      "permanent": true
    },
    {
      "source": "/sitemap_index.xml",
      "destination": "/sitemap.xml",
      "permanent": true
    }
  ],
  
  "crons": [
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 9 * * *"
    }
  ],
  
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
} 