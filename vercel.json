{
  "redirects": [
    // Old WordPress scholarship redirects
    {
      "source": "/scholarship/:slug",
      "destination": "/scholarships/:slug",
      "permanent": true
    },
    {
      "source": "/scholarships/:slug",
      "destination": "/scholarships/:slug",
      "permanent": true
    },
    {
      "source": "/category/scholarships/:slug",
      "destination": "/scholarships/:slug",
      "permanent": true
    },
    
    // Old blog post redirects
    {
      "source": "/:year/:month/:day/:slug",
