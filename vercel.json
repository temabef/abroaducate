      "destination": "/contact",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy",
      "permanent": true
    },
    {
      "source": "/terms-of-service",
      "destination": "/terms",
      "permanent": true
    },
    
    // Old tool redirects
    {
      "source": "/tools/gpa-converter",
      "destination": "/gpa-converter",
      "permanent": true
    },
    {
      "source": "/tools/word-optimization",
