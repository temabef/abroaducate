+		if (programIds.length === 0) return;
+		const { data: progData } = await supabase.from('programs').select('*').in('id', programIds);
+		const dbPrograms: any[] = progData ?? [];
+
+		// 4. Build the trackedProgramsData array
+		const built: any[] = interactionList
+			.map((interaction: any) => {
+				const p = dbPrograms.find((p: any) => p.id === interaction.program_id);
+				if (!p) return null;
+				return {
+					id: interaction.id,
+					status: interaction.status,
+					matchScore: interaction.match_score ?? null,
+					workspaceData: interaction.workspace_data ?? null,
+					addedAt: new Date(interaction.created_at).toLocaleDateString(),
+					program: p
+				};
+			})
+			.filter(Boolean);
+
+		// 5. If incoming program isn't tracked yet, prepend as a preview entry
+		if (urlProgramId && !built.some((t: any) => t.program?.id === urlProgramId)) {
+			const prog = dbPrograms.find((p: any) => p.id === urlProgramId);
+			if (prog)
+				built.unshift({
+					id: null,
+					status: 'saved',
+					matchScore: null,
+					workspaceData: null,
+					addedAt: new Date().toLocaleDateString(),
+					program: prog
+				});
+		}
+
+		// 6. Set state (triggers reactive update across the whole component)
+		trackedProgramsData = built;
+
+		// 7. If programId in URL, go directly to program detail
+		if (urlProgramId) {
+			const match = built.find((p: any) => p.program?.id === urlProgramId);
+			if (match) {
+				selectProgram(urlProgramId, match.workspaceData);
+				currentView = 'program-detail';
+			}
+		}
+		// If scholarshipId in URL, go to scholarship detail
+		if (urlScholarshipId) {
+			detailScholarshipId = urlScholarshipId;
+			currentView = 'scholarship-detail';
+		}
+	});
+
+	const statsReady = $derived(
+		trackedPrograms.filter((p: any) => p.status === 'ready' || p.status === 'submitted').length
+	);
 </script>
 
